{
  "name": "nova-build-tracker",
  "version": "0.2.0",
  "private": true,
  "description": "Manufacturing component build tracker — React + TypeScript + Apollo GraphQL + PostgreSQL",
  "homepage": "https://github.com/TheRobBrennan/nova-build-tracker#readme",
  "bugs": {
    "url": "https://github.com/TheRobBrennan/nova-build-tracker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheRobBrennan/nova-build-tracker.git"
  },
  "author": "Rob Brennan <rob@sploosh.ai>",
  "workspaces": [
    "services/*"
  ],
  "scripts": {
    "start": "docker compose up",
    "start:clean": "docker compose up --build",
    "start:dev": "docker compose --profile storybook up",
    "start:dev:clean": "docker compose --profile storybook up --build",
    "stop": "docker compose --profile storybook down",
    "clean": "docker compose --profile storybook down -v",
    "logs": "docker compose logs -f",
    "logs:api": "docker compose logs -f api",
    "logs:web": "docker compose logs -f web",
    "test": "npm run test:services && npm run test:workflows:validate",
    "test:services": "npm run test -w services/api && npm run test -w services/web",
    "test:api": "npm run test -w services/api",
    "test:api:watch": "npm run test:watch -w services/api",
    "test:api:coverage": "npm run test:coverage -w services/api",
    "test:web": "npm run test -w services/web",
    "test:web:watch": "npm run test:watch -w services/web",
    "test:web:coverage": "npm run test:coverage -w services/web",
    "test:workflows": "chmod +x .github/test-workflows.sh && .github/test-workflows.sh",
    "test:workflows:validate": "chmod +x .github/validate-workflows.sh && .github/validate-workflows.sh",
    "storybook": "npm run storybook -w services/web",
    "storybook:build": "npm run build-storybook -w services/web",
    "storybook:docker": "docker compose --profile storybook up storybook",
    "storybook:logs": "docker compose logs -f storybook"
  },
  "overrides": {
    "@types/express": "^4.17.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
